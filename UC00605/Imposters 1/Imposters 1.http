### Ex2 - Stub: pesquisa de carros por marca (GET /api/cars?brand=Toyota)
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "GET",
          "path": "/api/cars",
          "query": { "brand": "Toyota" }
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 200,
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "brand": "Toyota",
            "results": [{
              "id": 1,
              "modelo": "Prius",
              "preco": "19999€"
            }
            ]
          }
        }
      }
    ]    
  }
}

