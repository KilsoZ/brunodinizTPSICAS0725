### Ex6 - Stub: criar utilizador (email duplicado) (POST /api/users com email específico)
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "POST",
          "path": "/api/users",
          "headers": {
            "Content-Type": "application/json"
          }
        } 
      },
      {
        "contains": {
          "body": 
          "\"email\":\"exists@example.com\""
          
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 409,
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "error": "email_exists",
            "message": "This email already exists"
          }
        }
      }
    ]    
  }
}

