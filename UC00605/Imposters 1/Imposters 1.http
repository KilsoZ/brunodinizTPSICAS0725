### ex8 - Stub: temperatura — campo obrigatório (POST /api/temperature sem field)
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "POST",
          "path": "/api/temperature",
          "headers": {
            "Content-Type": "application/json"
          }
        } 
      },
      {
        "not": {
        "contains": {
         "body": "\"value\""
        }
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 400,
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "error": "missing_field",
            "message": "Value é obrigatório"
          }
        }
      }
    ]    
  }
}

