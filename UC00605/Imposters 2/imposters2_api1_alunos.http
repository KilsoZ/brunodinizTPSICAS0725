### Stub 400 POST /api/alunos
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
        {
            "matches": {
            "body": "\"idade\":\\s*[0-9]\\b"
            }
        }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 400,
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "error": "wrong_age",
            "message": "Idade do aluno é menor do que 10 anos."
          }
        }
      }
    ]    
  }
}

### Stub 404 curso Inexistente POST /api/alunos
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{ 
  "stub": {
    "predicates": [
      {
        "contains": {
            "body": "\"curso\":\"Cristianismo\""
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 404,
          "body": {
            "error": "not_found",
            "message": "Curso não existente"
          }
        }
      }
    ]    
  }  
}


### Stub 201 POST /api/alunos
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "POST",
          "path": "/api/alunos",
          "headers": {
            "Content-Type": "application/json"
          }
        } 
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 201,
          "headers": {
            "Content-Type": "application/json",
            "Location": "/api/alunos/4"
          },
          "body": {
            "id": "4",
            "status": "created",
            "message": "Aluno criado com sucesso"
          }
        }
      }
    ]    
  }
}

