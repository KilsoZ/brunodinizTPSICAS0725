### Por questão de consistencia, aqui um Delete para apagar imposters e fazer os exercicios seguidos
DELETE http://localhost:2525/imposters

### 2. API Gestão de Clientes e pEdidos

### Criaçao do Imposter
POST http://localhost:2525/imposters
Content-Type: application/json

{
  "port": 3000,
  "protocol": "http",
  "name": "imposter-clientes-pedidos"
}

### Stub 200 GET /api/clientes
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "GET",
          "path": "/api/clientes"
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 200,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "clientes": [
              { "id": 1, "nome": "Ana Silva", "email": "ana@email.com" },
              { "id": 2, "nome": "João Costa", "email": "joao@email.com" },
              { "id": 3, "nome": "Maria Sousa", "email": "maria@email.com" }
            ]
          }
        }
      }
    ]
  }
}

### Stub 400 POST /api/clientes - campos em falta
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "deepEquals": {
          "method": "POST",
          "path": "/api/clientes",
          "body": {
            "nome": "Rui Ferreira"
          }
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 400,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "error": "missing_fields",
            "message": "Os campos nome e email são obrigatórios"
          }
        }
      }
    ]
  }
}

### Stub 201 POST /api/clientes - criado com sucesso
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "POST",
          "path": "/api/clientes",
          "headers": { "Content-Type": "application/json" }
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 201,
          "headers": {
            "Content-Type": "application/json",
            "Location": "/api/clientes/4"
          },
          "body": {
            "id": 4,
            "status": "created",
            "message": "Cliente criado com sucesso"
          }
        }
      }
    ]
  }
}

