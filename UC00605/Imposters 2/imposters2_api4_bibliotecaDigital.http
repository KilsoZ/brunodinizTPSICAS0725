### Stub 409 POST /api/emprestimos - livro já emprestado
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "POST",
          "path": "/api/emprestimos",
          "body": {
            "cliente": "Bruno Teste",
            "livro_id": 2,
            "data_emprestimo": "2025-06-01"
          }
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 409,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "error": "book_unavailable",
            "message": "O livro já se encontra emprestado"
          }
        }
      }
    ]    
  }
}

### Stub 400 POST /api/emprestimos - campos em falta
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": { "method": "POST", "path": "/api/emprestimos" }
      },
      {
        "not": {
          "contains": { "body": "livro_id" }
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 400,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "error": "missing_fields",
            "message": "Os campos cliente, livro_id e data_emprestimo são obrigatórios"
          }
        }
      }
    ]    
  }
}

### Stub 201 POST /api/emprestimos - criado com sucesso
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "POST",
          "path": "/api/emprestimos",
          "headers": { "Content-Type": "application/json" }
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 201,
          "headers": {
            "Content-Type": "application/json",
            "Location": "/api/emprestimos/1"
          },
          "body": {
            "id": 1,
            "status": "created",
            "message": "Empréstimo registado com sucesso"
          }
        }
      }
    ]    
  }
}

