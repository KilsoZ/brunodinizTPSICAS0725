### Stub 400 POST - campos obrigatórios em falta
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "responses": [
      {
        "is": {
          "statusCode": 400,
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "error": "missing_fields",
            "message": "Campos cliente, checkin, checkout e tipo_quarto obrigatórios"
          }
        }
      }
    ],
    "predicates": [
        {
        "equals": { "method": "POST", "path": "/api/reservas" }
      },
      {
        "not": {
          "contains": { "body": "tipo_quarto" }
        }
      }
    ]
  }
}

