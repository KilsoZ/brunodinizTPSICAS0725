### Por questão de consistencia, aqui um Delete para apagar imposters e fazer os exercicios seguidos
DELETE http://localhost:2525/imposters

### 2. API 5 Gestão de funcionarios

### Criaçao do Imposter
POST http://localhost:2525/imposters
Content-Type: application/json

{
  "port": 3000,
  "protocol": "http",
  "name": "imposter-funcionarios"
}

### Stub 200 GET /api/funcionarios
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "GET",
          "path": "/api/funcionarios"
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 200,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "funcionarios": [
              { "id": 1, "nome": "Ana Silva", "cargo": "Rececionista", "salario": 900 },
              { "id": 2, "nome": "João Costa", "cargo": "Gerente", "salario": 1500 },
              { "id": 3, "nome": "Maria Sousa", "cargo": "Técnica", "salario": 1100 }
            ]
          }
        }
      }
    ]    
  }
}

### Teste GET /api/funcionarios (200)
GET http://localhost:3000/api/funcionarios

### Stub 400 POST /api/funcionarios - salário abaixo do mínimo
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "POST",
          "path": "/api/funcionarios",
          "body": {
            "nome": "Rui Ferreira",
            "cargo": "Assistente",
            "salario": 500
          }
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 400,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "error": "invalid_salary",
            "message": "O salário não pode ser inferior a 760€"
          }
        }
      }
    ]    
  }
}

### Stub 400 POST /api/funcionarios - campos em falta
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": { "method": "POST", "path": "/api/funcionarios" }
      },
      {
        "not": {
          "contains": { "body": "salario" }
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 400,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "error": "missing_fields",
            "message": "Os campos nome, cargo e salario são obrigatórios"
          }
        }
      }
    ]    
  }
}

### Stub 201 POST /api/funcionarios - criado com sucesso
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "POST",
          "path": "/api/funcionarios",
          "headers": { "Content-Type": "application/json" }
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 201,
          "headers": {
            "Content-Type": "application/json",
            "Location": "/api/funcionarios/4"
          },
          "body": {
            "id": 4,
            "status": "created",
            "message": "Funcionário criado com sucesso"
          }
        }
      }
    ]    
  }
}

