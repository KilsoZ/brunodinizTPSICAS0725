### Stub 200 DELETE /api/produtos/{id}
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "responses": [
      {
        "is": {
          "statusCode": 200,
          "headers": {
            "Content-Type": "application/json"
          }
        }
      }
    ],
    "predicates": [
