### Stub 400 POST /api/tarefas - título vazio
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "responses": [
      {
        "is": {
          "statusCode": 400,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "error": "invalid_title",
            "message": "O título não pode ser vazio"
          }
        }
      }
    ],
    "predicates": [
      {
        "equals": {
          "method": "POST",
          "path": "/api/tarefas",
          "body": {
            "titulo": "",
            "descricao": "Descrição qualquer"
          }
        }
      }
    ]
  }
}

### Stub 400 POST /api/tarefas - campos em falta
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "responses": [
      {
        "is": {
          "statusCode": 400,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "error": "missing_fields",
            "message": "Os campos titulo e descricao são obrigatórios"
          }
        }
      }
    ],
    "predicates": [
      {
        "equals": { "method": "POST", "path": "/api/tarefas" }
      },
      {
        "not": {
          "contains": { "body": "descricao" }
        }
      }
    ]
  }
}

### Stub 201 POST /api/tarefas - criada com sucesso
POST http://localhost:2525/imposters/3000/stubs
Content-Type: application/json

{
  "stub": {
    "responses": [
      {
        "is": {
          "statusCode": 201,
          "headers": {
            "Content-Type": "application/json",
            "Location": "/api/tarefas/4"
          },
          "body": {
            "id": 4,
            "status": "created",
            "message": "Tarefa criada com sucesso"
          }
        }
      }
    ],
    "predicates": [
      {
        "equals": {
          "method": "POST",
          "path": "/api/tarefas",
          "headers": { "Content-Type": "application/json" }
        }
      }
    ]
  }
}

